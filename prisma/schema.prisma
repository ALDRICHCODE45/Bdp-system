// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum ColaboradorEstado {
  CONTRATADO
  DESPEDIDO
}

enum ClienteProveedorTipo {
  CLIENTE
  PROVEEDOR
}

enum EgresoClasificacion {
  GASTO_OP
  HONORARIOS
  SERVICIOS
  ARRENDAMIENTO
  COMISIONES
  DISPOSICION
}

enum EgresoCategoria {
  FACTURACION
  COMISIONES
  DISPOSICION
  BANCARIZACIONES
}

enum EgresoFormaPago {
  TRANSFERENCIA
  EFECTIVO
  CHEQUE
}

enum EgresoCargoAbono {
  BDP
  CALFC
  GLOBAL
  RJZ
  APP
}

enum EgresoEstado {
  PAGADO
  PENDIENTE
  CANCELADO
}

enum EgresoFacturadoPor {
  BDP
  CALFC
  GLOBAL
  RGZ
  RJS
  APP
}

model Socio {
  id                      String             @id @default(uuid())
  nombre                  String
  email                   String             @unique
  telefono                String?
  activo                  Boolean            @default(true)
  fechaIngreso            DateTime           @default(now())
  departamento            String?
  numeroEmpleados         Int                @default(0)
  notas                   String?
  colaboradores           Colaborador[]
  clientesProveedores     ClienteProveedor[]
  egresosComSolicitante   Egreso[]           @relation("EgresoSolicitante")
  egresosComoAutorizador  Egreso[]           @relation("EgresoAutorizador")
  ingresosComSolicitante  Ingreso[]          @relation("IngresoSolicitante")
  ingresosComoAutorizador Ingreso[]          @relation("IngresoAutorizador")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  asuntosJuridicos        AsuntoJuridico[]
  registrosHoraJuridico   RegistroHora[]

  @@index([email])
  @@index([activo])
}

model Colaborador {
  id                           String                 @id @default(uuid())
  name                         String
  correo                       String                 @unique
  puesto                       String
  status                       ColaboradorEstado      @default(CONTRATADO)
  imss                         Boolean                @default(true)
  socioId                      String?
  socio                        Socio?                 @relation(fields: [socioId], references: [id], onDelete: SetNull)
  // Datos personales
  fechaIngreso                 DateTime               @default(now())
  genero                       String?
  fechaNacimiento              DateTime?
  nacionalidad                 String?
  estadoCivil                  String?
  tipoSangre                   String?
  // Contacto y dirección
  direccion                    String?
  telefono                     String?
  // Datos fiscales
  rfc                          String?
  curp                         String?
  // Académicos y laborales previos
  ultimoGradoEstudios          String?
  escuela                      String?
  ultimoTrabajo                String?
  // Referencias personales
  nombreReferenciaPersonal     String?
  telefonoReferenciaPersonal   String?
  parentescoReferenciaPersonal String?
  // Referencias laborales
  nombreReferenciaLaboral      String?
  telefonoReferenciaLaboral    String?
  // Datos financieros actuales
  banco                        String
  clabe                        String
  sueldo                       Decimal                @db.Decimal(15, 3)
  activos                      String[]
  historial                    ColaboradorHistorial[]
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  asistencias                  Asistencia[]

  @@index([socioId])
  @@index([status])
}

model ColaboradorHistorial {
  id            String      @id @default(uuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  campo         String
  valorAnterior String?
  valorNuevo    String
  usuarioId     String?
  motivo        String?
  fechaCambio   DateTime    @default(now())

  @@index([colaboradorId])
  @@index([fechaCambio])
}

model ClienteProveedorHistorial {
  id                 String           @id @default(uuid())
  clienteProveedorId String
  clienteProveedor   ClienteProveedor @relation(fields: [clienteProveedorId], references: [id], onDelete: Cascade)
  campo              String
  valorAnterior      String?
  valorNuevo         String
  usuarioId          String?
  motivo             String?
  fechaCambio        DateTime         @default(now())

  @@index([clienteProveedorId])
  @@index([fechaCambio])
}

model EntradasSalidas {
  id              String    @id @default(uuid())
  visitante       String
  destinatario    String
  motivo          String
  telefono        String?
  correspondencia String?
  fecha           DateTime
  hora_entrada    DateTime
  hora_salida     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([createdAt])
}

model User {
  id                         String             @id @default(uuid())
  email                      String             @unique
  name                       String
  password                   String
  roles                      UserRole[]
  isActive                   Boolean            @default(true)
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  clientesProveedoresCreados ClienteProveedor[] @relation("ClienteProveedorIngresadoPor")
  egresosCreados             Egreso[]           @relation("EgresoIngresadoPor")
  ingresosCreados            Ingreso[]          @relation("IngresoIngresadoPor")
  facturasCreadas            Factura[]          @relation("FacturaIngresadoPor")
  equiposJuridicos           EquipoJuridicoUsuario[]
  registrosHora              RegistroHora[]
  autorizacionesSolicitadas  AutorizacionEdicion[]  @relation("AutorizacionSolicitante")
  autorizacionesResueltas    AutorizacionEdicion[]  @relation("AutorizacionAutorizador")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  resource    String
  action      String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([resource])
  @@index([name])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model ClienteProveedor {
  id                      String                      @id @default(uuid())
  nombre                  String
  rfc                     String
  tipo                    ClienteProveedorTipo
  direccion               String
  telefono                String
  email                   String
  contacto                String
  numeroCuenta            String?
  clabe                   String?
  banco                   String?
  activo                  Boolean                     @default(true)
  fechaRegistro           DateTime                    @default(now())
  notas                   String?
  socioId                 String?
  socio                   Socio?                      @relation(fields: [socioId], references: [id], onDelete: SetNull)
  ingresadoPor            String?
  ingresadoPorRef         User?                       @relation("ClienteProveedorIngresadoPor", fields: [ingresadoPor], references: [id], onDelete: SetNull)
  egresosComoProveedor    Egreso[]                    @relation("EgresoProveedor")
  egresosComoClienteProye Egreso[]                    @relation("EgresoClienteProyecto")
  ingresosComoCliente     Ingreso[]                   @relation("IngresoCliente")
  historial               ClienteProveedorHistorial[]
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@unique([rfc, tipo])
  @@index([activo])
  @@index([socioId])
  @@index([ingresadoPor])
}

model Egreso {
  id                 String              @id @default(uuid())
  concepto           String
  clasificacion      EgresoClasificacion
  categoria          EgresoCategoria
  proveedor          String
  proveedorId        String
  proveedorRef       ClienteProveedor    @relation("EgresoProveedor", fields: [proveedorId], references: [id], onDelete: Restrict)
  solicitanteId      String?
  solicitanteRef     Socio?              @relation("EgresoSolicitante", fields: [solicitanteId], references: [id], onDelete: Restrict)
  autorizadorId      String?
  autorizadorRef     Socio?              @relation("EgresoAutorizador", fields: [autorizadorId], references: [id], onDelete: Restrict)
  numeroFactura      String
  folioFiscal        String
  periodo            String
  formaPago          EgresoFormaPago
  origen             String
  numeroCuenta       String
  clabe              String
  cargoAbono         EgresoCargoAbono
  cantidad           Decimal             @db.Decimal(15, 2)
  estado             EgresoEstado
  fechaPago          DateTime?
  fechaRegistro      DateTime            @default(now())
  facturadoPor       EgresoFacturadoPor
  clienteProyecto    String?
  clienteProyectoId  String?
  clienteProyectoRef ClienteProveedor?   @relation("EgresoClienteProyecto", fields: [clienteProyectoId], references: [id], onDelete: Restrict)
  facturaId          String?
  notas              String?
  ingresadoPor       String?
  ingresadoPorRef    User?               @relation("EgresoIngresadoPor", fields: [ingresadoPor], references: [id], onDelete: SetNull)
  historial          EgresoHistorial[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([estado])
  @@index([periodo])
  @@index([proveedorId])
  @@index([clienteProyectoId])
  @@index([fechaPago])
  @@index([createdAt])
  @@index([ingresadoPor])
  @@index([solicitanteId])
  @@index([autorizadorId])
  @@index([estado, createdAt])
  @@index([periodo, createdAt])
}

model EgresoHistorial {
  id            String   @id @default(uuid())
  egresoId      String
  egreso        Egreso   @relation(fields: [egresoId], references: [id], onDelete: Cascade)
  campo         String
  valorAnterior String?
  valorNuevo    String
  usuarioId     String?
  motivo        String?
  fechaCambio   DateTime @default(now())

  @@index([egresoId])
  @@index([fechaCambio])
}

enum IngresoFormaPago {
  TRANSFERENCIA
  EFECTIVO
  CHEQUE
}

enum IngresoEstado {
  PAGADO
  PENDIENTE
  CANCELADO
}

enum IngresoCargoAbono {
  BDP
  CALFC
}

enum IngresoFacturadoPor {
  BDP
  CALFC
  GLOBAL
  RGZ
  RJS
  APP
}

enum FacturaEstado {
  VIGENTE
  CANCELADA
}

enum FileAttachmentEntityType {
  FACTURA
  EGRESO
  INGRESO
  CLIENTE_PROVEEDOR
}

model Ingreso {
  id                 String              @id @default(uuid())
  concepto           String
  cliente            String
  clienteId          String
  clienteRef         ClienteProveedor    @relation("IngresoCliente", fields: [clienteId], references: [id], onDelete: Restrict)
  solicitanteId      String?
  solicitanteRef     Socio?              @relation("IngresoSolicitante", fields: [solicitanteId], references: [id], onDelete: Restrict)
  autorizadorId      String?
  autorizadorRef     Socio?              @relation("IngresoAutorizador", fields: [autorizadorId], references: [id], onDelete: Restrict)
  numeroFactura      String
  folioFiscal        String              @unique
  periodo            String
  formaPago          IngresoFormaPago
  origen             String
  numeroCuenta       String
  clabe              String
  cargoAbono         IngresoCargoAbono
  cantidad           Decimal             @db.Decimal(15, 2)
  estado             IngresoEstado
  fechaPago          DateTime?
  fechaRegistro      DateTime            @default(now())
  facturadoPor       IngresoFacturadoPor
  clienteProyecto    String
  fechaParticipacion DateTime?
  facturaId          String?
  notas              String?
  ingresadoPor       String?
  ingresadoPorRef    User?               @relation("IngresoIngresadoPor", fields: [ingresadoPor], references: [id], onDelete: SetNull)
  historial          IngresoHistorial[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([estado])
  @@index([periodo])
  @@index([clienteId])
  @@index([fechaPago])
  @@index([createdAt])
  @@index([ingresadoPor])
  @@index([solicitanteId])
  @@index([autorizadorId])
  @@index([estado, createdAt])
  @@index([periodo, createdAt])
}

model IngresoHistorial {
  id            String   @id @default(uuid())
  ingresoId     String
  ingreso       Ingreso  @relation(fields: [ingresoId], references: [id], onDelete: Cascade)
  campo         String
  valorAnterior String?
  valorNuevo    String
  usuarioId     String?
  motivo        String?
  fechaCambio   DateTime @default(now())

  @@index([ingresoId])
  @@index([fechaCambio])
}

model Factura {
  id String @id @default(uuid())

  // Datos CFDI
  concepto                   String
  serie                      String?
  folio                      String?
  fechaEmision               DateTime?
  subtotal                   Decimal          @db.Decimal(15, 2)
  iva                        Decimal?         @db.Decimal(15, 2)
  totalImpuestosTransladados Decimal?         @db.Decimal(15, 2)
  totalImpuestosRetenidos    Decimal?         @db.Decimal(15, 2)
  total                      Decimal          @db.Decimal(15, 2)
  uuid                       String           @unique
  rfcEmisor                  String
  nombreReceptor             String?
  rfcReceptor                String
  metodoPago                 String?
  medioPago                  String?
  moneda                     String           @default("MXN")
  usoCfdi                    String?
  status                     FacturaEstado    @default(VIGENTE)
  nombreEmisor               String?
  statusPago                 String?
  fechaPago                  DateTime?
  facturaUrl                 String?

  // Auditoria
  ingresadoPor    String?
  ingresadoPorRef User?              @relation("FacturaIngresadoPor", fields: [ingresadoPor], references: [id], onDelete: SetNull)
  historial       FacturaHistorial[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([ingresadoPor])
  @@index([status, createdAt])
  @@index([moneda])
  @@index([rfcEmisor])
  @@index([rfcReceptor])
  @@index([metodoPago])
  @@index([medioPago])
  @@index([statusPago])
  @@index([total])
  @@index([fechaPago])
}

model FacturaHistorial {
  id            String   @id @default(uuid())
  facturaId     String
  factura       Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  campo         String
  valorAnterior String?
  valorNuevo    String
  usuarioId     String?
  motivo        String?
  fechaCambio   DateTime @default(now())

  @@index([facturaId])
  @@index([fechaCambio])
}

model Empresa {
  id              String  @id @default(uuid())
  // Datos básicos
  razonSocial     String?
  nombreComercial String?
  rfc             String? @unique
  curp            String?
  // Dirección fiscal
  direccionFiscal String?
  colonia         String?
  ciudad          String?
  estado          String?
  codigoPostal    String?
  pais            String  @default("México")

  // Datos bancarios principales (targeta de credito o debito)
  bancoPrincipal           String?
  nombreEnTarjetaPrincipal String?
  numeroCuentaPrincipal    String?
  clabePrincipal           String?
  fechaExpiracionPrincipal DateTime?
  cvvPrincipal             Int?

  // Datos bancarios secundarios (opcional, targeta de credito o debito)
  bancoSecundario           String?
  nombreEnTarjetaSecundario String?
  numeroCuentaSecundario    String?
  clabeSecundaria           String?
  fechaExpiracionSecundaria DateTime?
  cvvSecundario             Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfc])
}

model FileAttachment {
  id         String                   @id @default(uuid())
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  entityType FileAttachmentEntityType
  entityId   String
  uploadedBy String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  @@index([entityType, entityId])
  @@index([entityId])
}

enum AsistenciaTipo {
  Entrada
  Salida
}

model Asistencia {
  id          String         @id @default(uuid())
  tipo        AsistenciaTipo
  fecha       DateTime
  correo      String
  colaborador Colaborador    @relation(fields: [correo], references: [correo], onDelete: Cascade)

  @@index([correo])
  @@index([fecha])
  @@index([tipo])
}

// ─── Módulo Jurídico ────────────────────────────────────────────────────────

enum AsuntoJuridicoEstado {
  ACTIVO
  INACTIVO
  CERRADO
}

enum AutorizacionEstado {
  PENDIENTE
  AUTORIZADA
  RECHAZADA
  UTILIZADA
}

model ClienteJuridico {
  id        String   @id @default(uuid())
  nombre    String
  rfc       String?
  contacto  String?
  email     String?
  telefono  String?
  direccion String?
  notas     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asuntos       AsuntoJuridico[]
  registrosHora RegistroHora[]

  @@index([activo])
  @@index([nombre])
}

model AsuntoJuridico {
  id                String               @id @default(uuid())
  nombre            String
  descripcion       String?
  estado            AsuntoJuridicoEstado @default(ACTIVO)
  clienteJuridicoId String
  clienteJuridico   ClienteJuridico      @relation(fields: [clienteJuridicoId], references: [id], onDelete: Restrict)
  socioId           String
  socio             Socio                @relation(fields: [socioId], references: [id], onDelete: Restrict)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  registrosHora RegistroHora[]

  @@index([clienteJuridicoId])
  @@index([socioId])
  @@index([estado])
}

model EquipoJuridico {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  miembros      EquipoJuridicoUsuario[]
  registrosHora RegistroHora[]

  @@index([activo])
  @@index([nombre])
}

model EquipoJuridicoUsuario {
  id        String         @id @default(uuid())
  equipoId  String
  equipo    EquipoJuridico @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   User           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([equipoId, usuarioId])
  @@index([equipoId])
  @@index([usuarioId])
}

model RegistroHora {
  id                String          @id @default(uuid())
  usuarioId         String
  usuario           User            @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  equipoJuridicoId  String
  equipoJuridico    EquipoJuridico  @relation(fields: [equipoJuridicoId], references: [id], onDelete: Restrict)
  clienteJuridicoId String
  clienteJuridico   ClienteJuridico @relation(fields: [clienteJuridicoId], references: [id], onDelete: Restrict)
  asuntoJuridicoId  String
  asuntoJuridico    AsuntoJuridico  @relation(fields: [asuntoJuridicoId], references: [id], onDelete: Restrict)
  socioId           String
  socio             Socio           @relation(fields: [socioId], references: [id], onDelete: Restrict)
  horas             Decimal         @db.Decimal(5, 2)
  descripcion       String?
  ano               Int
  semana            Int
  editable          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  historial      RegistroHoraHistorial[]
  autorizaciones AutorizacionEdicion[]

  @@index([usuarioId])
  @@index([equipoJuridicoId])
  @@index([clienteJuridicoId])
  @@index([asuntoJuridicoId])
  @@index([socioId])
  @@index([ano, semana])
  @@index([usuarioId, ano, semana])
  @@index([createdAt])
}

model RegistroHoraHistorial {
  id             String       @id @default(uuid())
  registroHoraId String
  registroHora   RegistroHora @relation(fields: [registroHoraId], references: [id], onDelete: Cascade)
  campo          String
  valorAnterior  String?
  valorNuevo     String
  usuarioId      String?
  motivo         String?
  fechaCambio    DateTime     @default(now())

  @@index([registroHoraId])
  @@index([fechaCambio])
}

model AutorizacionEdicion {
  id             String             @id @default(uuid())
  registroHoraId String
  registroHora   RegistroHora       @relation(fields: [registroHoraId], references: [id], onDelete: Cascade)
  solicitanteId  String
  solicitante    User               @relation("AutorizacionSolicitante", fields: [solicitanteId], references: [id], onDelete: Restrict)
  autorizadorId  String?
  autorizador    User?              @relation("AutorizacionAutorizador", fields: [autorizadorId], references: [id], onDelete: SetNull)
  justificacion  String
  estado         AutorizacionEstado @default(PENDIENTE)
  motivoRechazo  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([registroHoraId])
  @@index([solicitanteId])
  @@index([estado])
}
