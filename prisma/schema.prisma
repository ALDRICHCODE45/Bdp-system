// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum ColaboradorEstado {
  CONTRATADO
  DESPEDIDO
  EN_LICENCIA
}

enum ModalidadTrabajo {
  REMOTO
  HIBRIDO
  PRESENCIAL
}

enum TipoContrato {
  INDEFINIDO
  TEMPORAL
  POR_OBRA
  PRACTICAS
  HONORARIOS
}

enum NivelSeniority {
  JUNIOR
  SEMI_SENIOR
  SENIOR
  LEAD
  GERENCIAL
}

enum AusenciaTipo {
  VACACIONES
  LICENCIA
  INCAPACIDAD
}

enum DocumentCategory {
  CONTRATO
  INE
  RFC
  COMPROBANTE_DOMICILIO
  OTRO
}

enum ClienteProveedorTipo {
  CLIENTE
  PROVEEDOR
}

enum MovimientoTipo {
  INGRESO
  EGRESO
}

enum MovimientoCategoria {
  FACTURACION
  COMISIONES
  DISPOSICION
  BANCARIZACIONES
  GASTO_OP
  HONORARIOS
  SERVICIOS
  ARRENDAMIENTO
}

enum MovimientoFormaPago {
  TRANSFERENCIA
  EFECTIVO
  CHEQUE
}

enum MovimientoCargoAbono {
  BDP
  CALFC
  GLOBAL
  RJZ
  APP
}

enum MovimientoEstado {
  PAGADO
  PENDIENTE
  CANCELADO
}

enum MovimientoFacturadoPor {
  BDP
  CALFC
  GLOBAL
  RGZ
  RJS
  APP
}

model Socio {
  id                         String             @id @default(uuid())
  nombre                     String
  email                      String             @unique
  telefono                   String?
  activo                     Boolean            @default(true)
  fechaIngreso               DateTime           @default(now())
  departamento               String?
  numeroEmpleados            Int                @default(0)
  notas                      String?
  colaboradores              Colaborador[]
  clientesProveedores        ClienteProveedor[]
  movimientosComoSolicitante Movimiento[]       @relation("MovimientoSolicitante")
  movimientosComoAutorizador Movimiento[]       @relation("MovimientoAutorizador")
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  asuntosJuridicos           AsuntoJuridico[]
  registrosHoraJuridico      RegistroHora[]

  @@index([email])
  @@index([activo])
}

model Colaborador {
  id                           String                       @id @default(uuid())
  name                         String
  correo                       String                       @unique
  puesto                       String
  status                       ColaboradorEstado            @default(CONTRATADO)
  imss                         Boolean                      @default(true)
  socioId                      String?
  socio                        Socio?                       @relation(fields: [socioId], references: [id], onDelete: SetNull)
  // Datos personales
  fechaIngreso                 DateTime                     @default(now())
  genero                       String?
  fechaNacimiento              DateTime?
  nacionalidad                 String?
  estadoCivil                  String?
  tipoSangre                   String?
  // Contacto y dirección
  direccion                    String?
  telefono                     String?
  // Datos fiscales
  rfc                          String?
  curp                         String?
  // Académicos y laborales previos
  ultimoGradoEstudios          String?
  escuela                      String?
  ultimoTrabajo                String?
  // Referencias personales
  nombreReferenciaPersonal     String?
  telefonoReferenciaPersonal   String?
  parentescoReferenciaPersonal String?
  // Referencias laborales
  nombreReferenciaLaboral      String?
  telefonoReferenciaLaboral    String?
  // Datos financieros actuales
  banco                        String
  clabe                        String
  sueldo                       Decimal                      @db.Decimal(15, 3)
  activos                      String[]
  // Perfil extendido (rh-colaboradores-completo · P0 — todos nullable)
  departamento                 String?
  nivel                        NivelSeniority?
  modalidad                    ModalidadTrabajo?
  tipoContrato                 TipoContrato?
  lugarTrabajo                 String?
  horario                      String?
  fechaSalida                  DateTime?
  nombrePreferido              String?
  documentoIdentidad           String?
  emailPersonal                String?
  bio                          String?
  historial                    ColaboradorHistorial[]
  emergencyContacts            EmergencyContact[]
  responsabilidades            ResponsabilidadCargo[]
  salaryHistory                ColaboradorSalaryHistory[]
  positionHistory              ColaboradorPositionHistory[]
  education                    EducationEntry[]
  absences                     AbsenceRecord[]
  vacationBalance              VacationBalance?
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  asistencias                  Asistencia[]

  @@index([socioId])
  @@index([status])
}

model ColaboradorHistorial {
  id            String      @id @default(uuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  campo         String
  valorAnterior String?
  valorNuevo    String
  usuarioId     String?
  motivo        String?
  fechaCambio   DateTime    @default(now())

  @@index([colaboradorId])
  @@index([fechaCambio])
}

model ClienteProveedorHistorial {
  id                 String           @id @default(uuid())
  clienteProveedorId String
  clienteProveedor   ClienteProveedor @relation(fields: [clienteProveedorId], references: [id], onDelete: Cascade)
  campo              String
  valorAnterior      String?
  valorNuevo         String
  usuarioId          String?
  motivo             String?
  fechaCambio        DateTime         @default(now())

  @@index([clienteProveedorId])
  @@index([fechaCambio])
}

model EntradasSalidas {
  id              String    @id @default(uuid())
  visitante       String
  destinatario    String
  motivo          String
  telefono        String?
  correspondencia String?
  fecha           DateTime
  hora_entrada    DateTime
  hora_salida     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([createdAt])
}

model User {
  id                         String                  @id @default(uuid())
  email                      String                  @unique
  name                       String
  password                   String
  roles                      UserRole[]
  isActive                   Boolean                 @default(true)
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  clientesProveedoresCreados ClienteProveedor[]      @relation("ClienteProveedorIngresadoPor")
  movimientosCreados         Movimiento[]            @relation("MovimientoIngresadoPor")
  facturasCreadas            Factura[]               @relation("FacturaIngresadoPor")
  equiposJuridicos           EquipoJuridicoUsuario[]
  registrosHora              RegistroHora[]
  autorizacionesSolicitadas  AutorizacionEdicion[]   @relation("AutorizacionSolicitante")
  autorizacionesResueltas    AutorizacionEdicion[]   @relation("AutorizacionAutorizador")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  resource    String
  action      String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([resource])
  @@index([name])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model ClienteProveedor {
  id                       String                      @id @default(uuid())
  nombre                   String
  rfc                      String
  tipo                     ClienteProveedorTipo
  direccion                String
  telefono                 String
  email                    String
  contacto                 String
  numeroCuenta             String?
  clabe                    String?
  banco                    String?
  activo                   Boolean                     @default(true)
  fechaRegistro            DateTime                    @default(now())
  notas                    String?
  socioId                  String?
  socio                    Socio?                      @relation(fields: [socioId], references: [id], onDelete: SetNull)
  ingresadoPor             String?
  ingresadoPorRef          User?                       @relation("ClienteProveedorIngresadoPor", fields: [ingresadoPor], references: [id], onDelete: SetNull)
  movimientosComoProveedor Movimiento[]                @relation("MovimientoProveedor")
  movimientosComoCliente   Movimiento[]                @relation("MovimientoCliente")
  historial                ClienteProveedorHistorial[]
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  @@unique([rfc, tipo])
  @@index([activo])
  @@index([socioId])
  @@index([ingresadoPor])
}

model Movimiento {
  id                 String         @id @default(uuid())
  tipo               MovimientoTipo
  titular            String
  estadoCuenta       String
  fechaCorte         DateTime
  fechaOperacion     DateTime
  descripcionLiteral String
  monto              Decimal        @db.Decimal(15, 2)
  dedupHash          String         @unique

  // Optional fields
  concepto                  String?
  descripcionAdministracion String?
  categoria                 MovimientoCategoria?
  formaPago                 MovimientoFormaPago?
  cargoAbono                MovimientoCargoAbono?
  facturadoPor              MovimientoFacturadoPor?
  periodo                   String?
  numeroFactura             String?
  folioFiscal               String?

  // Proveedor (text + optional FK)
  proveedor    String?
  proveedorId  String?
  proveedorRef ClienteProveedor? @relation("MovimientoProveedor", fields: [proveedorId], references: [id], onDelete: SetNull)

  // Cliente (text + optional FK)
  cliente    String?
  clienteId  String?
  clienteRef ClienteProveedor? @relation("MovimientoCliente", fields: [clienteId], references: [id], onDelete: SetNull)

  // People references
  solicitanteId  String?
  solicitanteRef Socio?  @relation("MovimientoSolicitante", fields: [solicitanteId], references: [id], onDelete: SetNull)
  autorizadorId  String?
  autorizadorRef Socio?  @relation("MovimientoAutorizador", fields: [autorizadorId], references: [id], onDelete: SetNull)

  // Other optional
  notas           String?
  facturaId       String?
  ingresadoPor    String?
  ingresadoPorRef User?            @relation("MovimientoIngresadoPor", fields: [ingresadoPor], references: [id], onDelete: SetNull)
  estado          MovimientoEstado @default(PAGADO)

  // Relations
  historial MovimientoHistorial[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([tipo])
  @@index([estado])
  @@index([tipo, estado])
  @@index([titular])
  @@index([fechaOperacion])
  @@index([fechaCorte])
  @@index([proveedorId])
  @@index([clienteId])
  @@index([solicitanteId])
  @@index([autorizadorId])
  @@index([ingresadoPor])
  @@index([createdAt])
  @@index([tipo, createdAt])
  @@index([estado, createdAt])
}

model MovimientoHistorial {
  id            String     @id @default(uuid())
  movimientoId  String
  movimiento    Movimiento @relation(fields: [movimientoId], references: [id], onDelete: Cascade)
  campo         String
  valorAnterior String?
  valorNuevo    String
  usuarioId     String?
  motivo        String?
  fechaCambio   DateTime   @default(now())

  @@index([movimientoId])
  @@index([fechaCambio])
}

enum FacturaEstado {
  VIGENTE
  CANCELADA
}

enum FileAttachmentEntityType {
  FACTURA
  MOVIMIENTO
  CLIENTE_PROVEEDOR
  COLABORADOR
}

model Factura {
  id String @id @default(uuid())

  // Datos CFDI
  concepto                   String
  serie                      String?
  folio                      String?
  fechaEmision               DateTime?
  subtotal                   Decimal       @db.Decimal(15, 2)
  iva                        Decimal?      @db.Decimal(15, 2)
  totalImpuestosTransladados Decimal?      @db.Decimal(15, 2)
  totalImpuestosRetenidos    Decimal?      @db.Decimal(15, 2)
  total                      Decimal       @db.Decimal(15, 2)
  uuid                       String        @unique
  rfcEmisor                  String
  nombreReceptor             String?
  rfcReceptor                String
  metodoPago                 String?
  medioPago                  String?
  moneda                     String        @default("MXN")
  usoCfdi                    String?
  status                     FacturaEstado @default(VIGENTE)
  nombreEmisor               String?
  statusPago                 String?
  fechaPago                  DateTime?
  facturaUrl                 String?
  originalFacturaUrl         String?

  // Auditoria
  ingresadoPor    String?
  ingresadoPorRef User?              @relation("FacturaIngresadoPor", fields: [ingresadoPor], references: [id], onDelete: SetNull)
  historial       FacturaHistorial[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([ingresadoPor])
  @@index([status, createdAt])
  @@index([moneda])
  @@index([rfcEmisor])
  @@index([rfcReceptor])
  @@index([metodoPago])
  @@index([medioPago])
  @@index([statusPago])
  @@index([total])
  @@index([fechaPago])
}

model FacturaHistorial {
  id            String   @id @default(uuid())
  facturaId     String
  factura       Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  campo         String
  valorAnterior String?
  valorNuevo    String
  usuarioId     String?
  motivo        String?
  fechaCambio   DateTime @default(now())

  @@index([facturaId])
  @@index([fechaCambio])
}

model Empresa {
  id              String  @id @default(uuid())
  // Datos básicos
  razonSocial     String?
  nombreComercial String?
  rfc             String? @unique
  curp            String?
  // Dirección fiscal
  direccionFiscal String?
  colonia         String?
  ciudad          String?
  estado          String?
  codigoPostal    String?
  pais            String  @default("México")

  // Datos bancarios principales (targeta de credito o debito)
  bancoPrincipal           String?
  nombreEnTarjetaPrincipal String?
  numeroCuentaPrincipal    String?
  clabePrincipal           String?
  fechaExpiracionPrincipal DateTime?
  cvvPrincipal             Int?

  // Datos bancarios secundarios (opcional, targeta de credito o debito)
  bancoSecundario           String?
  nombreEnTarjetaSecundario String?
  numeroCuentaSecundario    String?
  clabeSecundaria           String?
  fechaExpiracionSecundaria DateTime?
  cvvSecundario             Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfc])
}

model FileAttachment {
  id              String                   @id @default(uuid())
  fileName        String
  fileUrl         String
  originalFileUrl String?
  fileSize        Int
  mimeType        String
  entityType      FileAttachmentEntityType
  entityId        String
  uploadedBy      String?
  expiryDate      DateTime?
  category        DocumentCategory?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([entityType, entityId])
  @@index([entityId])
}

enum AsistenciaTipo {
  Entrada
  Salida
}

model Asistencia {
  id          String         @id @default(uuid())
  tipo        AsistenciaTipo
  fecha       DateTime
  correo      String
  colaborador Colaborador    @relation(fields: [correo], references: [correo], onDelete: Cascade)

  @@index([correo])
  @@index([fecha])
  @@index([tipo])
}

// ─── rh-colaboradores-completo · P0 (schema foundation) ────────────────────

model EmergencyContact {
  id            String      @id @default(uuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  nombre        String
  parentesco    String
  telefono      String
  email         String?
  notas         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([colaboradorId])
}

model ResponsabilidadCargo {
  id            String      @id @default(uuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  descripcion   String
  orden         Int         @default(0)
  completada    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([colaboradorId])
}

model ColaboradorSalaryHistory {
  id            String      @id @default(uuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  fechaEfectiva DateTime
  monto         Decimal     @db.Decimal(15, 3)
  moneda        String      @default("MXN")
  motivo        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([colaboradorId])
  @@index([colaboradorId, fechaEfectiva])
}

model ColaboradorPositionHistory {
  id            String          @id @default(uuid())
  colaboradorId String
  colaborador   Colaborador     @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  fechaEfectiva DateTime
  cargo         String
  departamento  String?
  nivel         NivelSeniority?
  motivo        String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([colaboradorId])
  @@index([colaboradorId, fechaEfectiva])
}

model EducationEntry {
  id            String      @id @default(uuid())
  colaboradorId String
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  institucion   String
  titulo        String
  anio          Int
  orden         Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([colaboradorId])
}

model AbsenceRecord {
  id              String       @id @default(uuid())
  colaboradorId   String
  colaborador     Colaborador  @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  tipo            AusenciaTipo
  fechaInicio     DateTime
  fechaFin        DateTime
  dias            Int
  motivo          String?
  registradoPorId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([colaboradorId])
  @@index([colaboradorId, tipo])
  @@index([fechaInicio])
}

model VacationBalance {
  id              String      @id @default(uuid())
  colaboradorId   String      @unique
  colaborador     Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  diasDisponibles Int         @default(0)
  diasTomados     Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ─── Módulo Jurídico ────────────────────────────────────────────────────────

enum AsuntoJuridicoEstado {
  ACTIVO
  INACTIVO
  CERRADO
}

enum AutorizacionEstado {
  PENDIENTE
  AUTORIZADA
  RECHAZADA
  UTILIZADA
}

model ClienteJuridico {
  id        String   @id @default(uuid())
  nombre    String
  rfc       String?
  contacto  String?
  email     String?
  telefono  String?
  direccion String?
  notas     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asuntos       AsuntoJuridico[]
  registrosHora RegistroHora[]

  @@index([activo])
  @@index([nombre])
}

model AsuntoJuridico {
  id                String               @id @default(uuid())
  nombre            String
  descripcion       String?
  estado            AsuntoJuridicoEstado @default(ACTIVO)
  clienteJuridicoId String
  clienteJuridico   ClienteJuridico      @relation(fields: [clienteJuridicoId], references: [id], onDelete: Restrict)
  socioId           String
  socio             Socio                @relation(fields: [socioId], references: [id], onDelete: Restrict)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  registrosHora RegistroHora[]

  @@index([clienteJuridicoId])
  @@index([socioId])
  @@index([estado])
}

model EquipoJuridico {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  miembros      EquipoJuridicoUsuario[]
  registrosHora RegistroHora[]

  @@index([activo])
  @@index([nombre])
}

model EquipoJuridicoUsuario {
  id        String         @id @default(uuid())
  equipoId  String
  equipo    EquipoJuridico @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   User           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([equipoId, usuarioId])
  @@index([equipoId])
  @@index([usuarioId])
}

model RegistroHora {
  id                String          @id @default(uuid())
  usuarioId         String
  usuario           User            @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  equipoJuridicoId  String
  equipoJuridico    EquipoJuridico  @relation(fields: [equipoJuridicoId], references: [id], onDelete: Restrict)
  clienteJuridicoId String
  clienteJuridico   ClienteJuridico @relation(fields: [clienteJuridicoId], references: [id], onDelete: Restrict)
  asuntoJuridicoId  String
  asuntoJuridico    AsuntoJuridico  @relation(fields: [asuntoJuridicoId], references: [id], onDelete: Restrict)
  socioId           String
  socio             Socio           @relation(fields: [socioId], references: [id], onDelete: Restrict)
  horas             Decimal         @db.Decimal(5, 2)
  descripcion       String?
  ano               Int
  semana            Int
  editable          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  historial      RegistroHoraHistorial[]
  autorizaciones AutorizacionEdicion[]

  @@index([usuarioId])
  @@index([equipoJuridicoId])
  @@index([clienteJuridicoId])
  @@index([asuntoJuridicoId])
  @@index([socioId])
  @@index([ano, semana])
  @@index([usuarioId, ano, semana])
  @@index([createdAt])
}

model RegistroHoraHistorial {
  id             String       @id @default(uuid())
  registroHoraId String
  registroHora   RegistroHora @relation(fields: [registroHoraId], references: [id], onDelete: Cascade)
  campo          String
  valorAnterior  String?
  valorNuevo     String
  usuarioId      String?
  motivo         String?
  fechaCambio    DateTime     @default(now())

  @@index([registroHoraId])
  @@index([fechaCambio])
}

model AutorizacionEdicion {
  id             String             @id @default(uuid())
  registroHoraId String
  registroHora   RegistroHora       @relation(fields: [registroHoraId], references: [id], onDelete: Cascade)
  solicitanteId  String
  solicitante    User               @relation("AutorizacionSolicitante", fields: [solicitanteId], references: [id], onDelete: Restrict)
  autorizadorId  String?
  autorizador    User?              @relation("AutorizacionAutorizador", fields: [autorizadorId], references: [id], onDelete: SetNull)
  justificacion  String
  estado         AutorizacionEstado @default(PENDIENTE)
  motivoRechazo  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([registroHoraId])
  @@index([solicitanteId])
  @@index([estado])
}
